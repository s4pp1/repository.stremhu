<?xml version='1.0' encoding='utf-8'?>
<addons><addon id="plugin.video.stremhu" name="StremHU" version="0.3.1" provider-name="StremHU">

  <requires>
    <import addon="xbmc.python" version="3.0.1" />
    <import addon="script.module.requests" version="2.31.0" />
    <import addon="script.module.routing" version="0.2.3+matrix.1" />
  </requires>

  <extension point="xbmc.python.pluginsource" library="resources/plugin.py">
    <provides>video</provides>
  </extension>
  <extension point="xbmc.service" library="resources/service.py" start="startup" />

  <extension point="xbmc.addon.metadata">
    <summary lang="hu_HU">StremHU</summary>
    <description lang="hu_HU" xml:space="preserve">Streamelj filmeket és sorozatokat közvetlenül magyar trackerekről a StremHU segítségével. Az addon egy háttérszolgáltatáson keresztül működik, ezért csatlakoznia kell egy futó StremHU Source-hoz (helyben vagy interneten keresztül).</description>
    <platform>all</platform>
    <website>https://stremhu.app</website>
    <license>GPL-3.0-or-later</license>
    <source>https://github.com/s4pp1/plugin.video.stremhu</source>
    <assets>
      <icon>icon.png</icon>
      <fanart>fanart.jpg</fanart>
    </assets>
  </extension>
</addon></addons>